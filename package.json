{
  "name": "lazy-patta",
  "version": "0.0.0",
  "private": true,
  "description": "Premium, nostalgic Indian family card-game platform. Not gambling.",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check-links": "node scripts/check-links.mjs",
    "check-domains": "node scripts/check-forbidden-domains.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "test:rls": "pnpm --filter @lazy-patta/supabase test:rls"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "supabase": "^2.109.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "@expo/metro-runtime": "57.0.5"
    }
  }
}

{
  "expo": {
    "name": "Lazy Patta",
    "slug": "lazy-patta",
    "scheme": "lazypatta",
    "version": "0.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/lazy-patta-ios-icon-opaque-maroon-1024.png",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/lazy-patta-ios-icon-opaque-maroon-1024.png",
      "associatedDomains": ["applinks:lazypatta.com"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/lazy-patta-logo-transparent.png",
        "backgroundColor": "#7A1F2B"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "lazypatta.com", "pathPrefix": "/join" },
            { "scheme": "https", "host": "lazypatta.com", "pathPrefix": "/play" },
            { "scheme": "https", "host": "lazypatta.com", "pathPrefix": "/games" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/lazy-patta-ios-icon-opaque-maroon-1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF7E8",
          "image": "./assets/images/lazy-patta-logo-transparent.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

# Lazy Patta — environment template.
# Copy to `.env.local` (git-ignored) and fill in real values. Never commit secrets.

# ─── Canonical site identity (browser-safe) ──────────────────────────────────
# The permanent public origin. Everything that emits an absolute URL (metadata,
# canonicals, sitemap, room invite links) derives from this. Leave it as the
# production domain; only override for local canonical testing. Never set this to
# a *.vercel.app preview URL — previews may RENDER from vercel.app but must still
# advertise the canonical domain.
NEXT_PUBLIC_SITE_URL=https://lazypatta.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@lazypatta.com

# ─── App store listings (browser-safe, optional) ─────────────────────────────
# When set, /download renders real store links. When empty, /download shows a
# "coming soon" state instead of dead badges. Fill in once the apps are live.
# NEXT_PUBLIC_IOS_APP_STORE_URL=
# NEXT_PUBLIC_GOOGLE_PLAY_URL=

# ─── Mobile deep-link association (server, optional) ──────────────────────────
# Supplied by the owner once native builds exist. Until ALL of a platform's
# values are present, /.well-known/apple-app-site-association (iOS) and
# /.well-known/assetlinks.json (Android) return 404 rather than shipping a bogus
# association. See docs/domain-migration-checklist.md for activation steps.
# APPLE_TEAM_ID=
# IOS_BUNDLE_ID=
# ANDROID_PACKAGE_NAME=
# ANDROID_SHA256_CERT_FINGERPRINT=

# ─── Web app (browser-safe) ──────────────────────────────────────────────────
# These are the ONLY Supabase values the browser is allowed to see. The anon key
# grants nothing beyond what Row Level Security permits, so it is safe to ship to
# the client. Absent these, online play degrades to a friendly "not configured"
# notice and guest computer play keeps working.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# ─── Server / tests only (NEVER expose to the browser) ───────────────────────
# The service-role key bypasses RLS. It must stay in server-side environments and
# is used by the RLS test harness to provision fixtures. Do not prefix it with
# NEXT_PUBLIC_ and never log it.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Set to 1 to run the live RLS + RPC behavioural tests against a running local
# Supabase (`pnpm supabase:start`). Unset for the default unit run.
# SUPABASE_RLS_LIVE=1
